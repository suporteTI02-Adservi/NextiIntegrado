{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "nextiintegrado",
  "version": "1.0.0",
  "identifier": "com.nexti.integrado",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Integração Nexti v1.0.0",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": ["resources/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "compression": "lzma",
        "installMode": "currentUser"
      },
      "webviewInstallMode": {
        "type": "skip"
      },
      "wix": {
        "language": "pt-BR"
      }
    }
  }
}
